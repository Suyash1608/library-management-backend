{
  "info": {
    "name": "Library Management API",
    "_postman_id": "library-management-collection-v1",
    "description": "Complete API collection for the Library Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082", "type": "string" },
    { "key": "memberToken", "value": "", "type": "string" },
    { "key": "librarianToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Member",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data && json.data.token) pm.collectionVariables.set('memberToken', json.data.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Suyash Gupta\",\n  \"email\": \"suyash@example.com\",\n  \"password\": \"pass1234\",\n  \"phone\": \"9876543210\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "Login Member",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data && json.data.token) pm.collectionVariables.set('memberToken', json.data.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"suyash@example.com\",\n  \"password\": \"pass1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Login Librarian",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data && json.data.token) pm.collectionVariables.set('librarianToken', json.data.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"librarian@example.com\",\n  \"password\": \"lib1234\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        }
      ]
    },
    {
      "name": "Books (Public)",
      "item": [
        {
          "name": "Get Available Books",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/available", "host": ["{{baseUrl}}"], "path": ["api","books","available"] }
          }
        },
        {
          "name": "Search Books",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/search?keyword=java", "host": ["{{baseUrl}}"], "path": ["api","books","search"], "query": [{ "key": "keyword", "value": "java" }] }
          }
        },
        {
          "name": "Get Book by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/1", "host": ["{{baseUrl}}"], "path": ["api","books","1"] }
          }
        }
      ]
    },
    {
      "name": "Books (Librarian)",
      "item": [
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api","books"] }
          }
        },
        {
          "name": "Add Book",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{librarianToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Clean Code\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"978-0132350884\",\n  \"genre\": \"Programming\",\n  \"publisher\": \"Prentice Hall\",\n  \"publishedYear\": 2008,\n  \"totalCopies\": 5\n}" },
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api","books"] }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{librarianToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Clean Code\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"978-0132350884\",\n  \"genre\": \"Programming\",\n  \"publisher\": \"Prentice Hall\",\n  \"publishedYear\": 2008,\n  \"totalCopies\": 8\n}" },
            "url": { "raw": "{{baseUrl}}/api/books/1", "host": ["{{baseUrl}}"], "path": ["api","books","1"] }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/books/1", "host": ["{{baseUrl}}"], "path": ["api","books","1"] }
          }
        }
      ]
    },
    {
      "name": "Borrow & Return (Member)",
      "item": [
        {
          "name": "Borrow Book",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/borrow/1", "host": ["{{baseUrl}}"], "path": ["api","borrow","1"] }
          }
        },
        {
          "name": "Return Book",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/borrow/return/1", "host": ["{{baseUrl}}"], "path": ["api","borrow","return","1"] }
          }
        },
        {
          "name": "My Active Borrows",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/borrow/my/active", "host": ["{{baseUrl}}"], "path": ["api","borrow","my","active"] }
          }
        },
        {
          "name": "My Borrow History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/borrow/my/history", "host": ["{{baseUrl}}"], "path": ["api","borrow","my","history"] }
          }
        }
      ]
    },
    {
      "name": "Borrow (Librarian)",
      "item": [
        {
          "name": "All Borrow Records",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/borrow", "host": ["{{baseUrl}}"], "path": ["api","borrow"] }
          }
        },
        {
          "name": "Get Overdue Records",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/borrow/overdue", "host": ["{{baseUrl}}"], "path": ["api","borrow","overdue"] }
          }
        },
        {
          "name": "Mark Overdue Records",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/borrow/mark-overdue", "host": ["{{baseUrl}}"], "path": ["api","borrow","mark-overdue"] }
          }
        }
      ]
    },
    {
      "name": "Members (Librarian)",
      "item": [
        {
          "name": "Get All Members",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/librarian/members", "host": ["{{baseUrl}}"], "path": ["api","librarian","members"] }
          }
        },
        {
          "name": "Get Member by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/librarian/members/1", "host": ["{{baseUrl}}"], "path": ["api","librarian","members","1"] }
          }
        },
        {
          "name": "Assign Librarian Role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/librarian/members/2/role?role=LIBRARIAN", "host": ["{{baseUrl}}"], "path": ["api","librarian","members","2","role"], "query": [{ "key": "role", "value": "LIBRARIAN" }] }
          }
        },
        {
          "name": "Toggle Member Status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/librarian/members/2/toggle-status", "host": ["{{baseUrl}}"], "path": ["api","librarian","members","2","toggle-status"] }
          }
        },
        {
          "name": "Delete Member",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/librarian/members/3", "host": ["{{baseUrl}}"], "path": ["api","librarian","members","3"] }
          }
        }
      ]
    }
  ]
}
